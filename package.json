{
	"name": "logbook",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "next dev --turbopack",
		"build": "next build",
		"start": "next start",
		"lint": "next lint",
		"test": "vitest",
		"test:ui": "vitest --ui",
		"check": "pnpm biome check",
		"check:write": "pnpm biome check --write",
		"ts-check": "tsc --noEmit",
		"db:": "bun run --env-file=.env.local drizzle-kit",
		"better-auth:generate": "bun run --env-file=.env.local node_modules/@better-auth/cli generate --output db/schema/auth.ts"
	},
	"dependencies": {
		"@auth/drizzle-adapter": "^1.4.1",
		"@heroui/react": "2.7.6",
		"@hookform/resolvers": "^4.0.0",
		"@internationalized/date": "^3.7.0",
		"@libsql/client": "^0.15.0",
		"@next-safe-action/adapter-react-hook-form": "^1.0.13",
		"@t3-oss/env-nextjs": "^0.12.0",
		"@tabler/icons-react": "^3.22.0",
		"better-auth": "^1.1.17",
		"drizzle-orm": "^0.41.0",
		"framer-motion": "^12.0.0",
		"next": "15.2.4",
		"next-safe-action": "^7.9.2",
		"react": "19.1.0",
		"react-dom": "19.1.0",
		"react-hook-form": "^7.53.0",
		"sonner": "^2.0.0",
		"uuid": "^11.0.0",
		"zod": "^3.23.8"
	},
	"devDependencies": {
		"@better-auth/cli": "1.2.5",
		"@biomejs/biome": "1.9.4",
		"@eslint/eslintrc": "3.3.1",
		"@eslint/js": "9.24.0",
		"@hookform/devtools": "4.4.0",
		"@types/bun": "1.2.8",
		"@types/node": "22.14.0",
		"@types/react": "19.1.0",
		"@types/react-dom": "19.1.1",
		"@types/uuid": "10.0.0",
		"@vitest/ui": "3.1.1",
		"drizzle-kit": "0.30.6",
		"eslint": "9.24.0",
		"eslint-config-next": "15.2.4",
		"jiti": "2.4.2",
		"postcss": "8.5.3",
		"tailwindcss": "3.4.17",
		"typescript": "5.8.3",
		"vite": "6.2.5",
		"vite-tsconfig-paths": "5.1.4",
		"vitest": "3.1.1"
